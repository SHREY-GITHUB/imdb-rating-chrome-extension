{
  "manifest_version": 3,
  "name": "IMDB Ratings for Prime & Hotstar",
  "version": "1.1.0",
  "description": "Shows IMDB ratings on the hero banner of Prime Video and Hotstar.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.primevideo.com/*",
    "https://*.amazon.com/*",
    "https://*.amazon.in/*",
    "https://*.hotstar.com/*",
    "https://*.disneyplus.com/*",
    "https://www.omdbapi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.primevideo.com/*",
        "https://*.amazon.com/*",
        "https://*.amazon.in/*",
        "https://*.hotstar.com/*",
        "https://*.disneyplus.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "IMDB Ratings"
  }
}
